# Required for voiceover + music generation
ELEVENLABS_API_KEY=

# Required for script generation
ANTHROPIC_API_KEY=

# Required for image-to-video animation (Phase 4)
GOOGLE_VEO_API_KEY=

# Required for talking-head animation via Fal OmniHuman (Phase 5)
FAL_KEY=

# Optional — only needed if using cloud storage providers (Phase 4+)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AZURE_STORAGE_CONNECTION_STRING=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
ELEVENLABS_MUSIC_MODEL=music_v1
FAL_OMNIHUMAN_MODEL=fal-ai/bytedance/omnihuman

# Path to your config file (defaults to ./promo-video.config.json next to cwd)
PROMO_VIDEO_CONFIG=
