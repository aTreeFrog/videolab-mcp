{
  "name": "videolab-mcp",
  "version": "0.1.0",
  "description": "MCP server for creating short-form videos and text-to-documentary content: music + b-roll + scene art + ElevenLabs voiceover + Veo animation, stitched with FFmpeg, with cheap iteration (swap music/voiceover/clip).",
  "type": "module",
  "bin": {
    "videolab-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "skills",
    "videolab.config.example.json",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video",
    "documentary",
    "elevenlabs",
    "ffmpeg",
    "veo"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@azure/storage-blob": "^12.25.0",
    "@fal-ai/client": "^1.7.2",
    "@google/genai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "mongodb": "^6.10.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
